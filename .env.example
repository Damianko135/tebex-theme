# Cloudflare D1
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""
CLOUDFLARE_D1_TOKEN=""

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Tebex
# 32 random bytes, base64-encoded (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
# In production, set this with `wrangler secret put TEBEX_ENCRYPTION_KEY` — never commit the real value.
TEBEX_ENCRYPTION_KEY=""
