{
	"name": "tebex",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"shadcn": "bun x shadcn-svelte@latest add --yes",
		"shadcn:update": "bun x shadcn-svelte@latest update --all --yes",
		"tebex:generate": "openapi-typescript openapi.yaml -o src/lib/tebex/headless/schema.d.ts",
		"tebex:update": "bun scripts/tebex-api.ts && bun run tebex:generate"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json,md,css}": [
			"prettier --write"
		],
		"*.{js,ts,svelte}": [
			"eslint --fix"
		]
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "^5.3.0",
		"@inlang/paraglide-js": "^2.22.0",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.25.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^26.1.1",
		"@vitest/browser-playwright": "^4.1.10",
		"better-auth": "~1.6.24",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.22.0",
		"formsnap": "^2.0.1",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.1.1",
		"mode-watcher": "^1.1.0",
		"openapi-typescript": "^7.13.0",
		"playwright": "^1.61.1",
		"postgres": "^3.4.9",
		"prettier": "^3.9.6",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.56.7",
		"svelte-check": "^4.7.3",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.65.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^3.0.0"
	}
}
